# ── 로컬 개발 ─────────────────────────────────────────────
VITE_BACKEND_API_BASE=/backend-api
VITE_KAKAO_MAP_KEY=your_kakao_javascript_key_here

# (선택) 백엔드 없이 프론트에서 ODcloud 직접 호출 시만
# VITE_ODCLOUD_SERVICE_KEY=your_odcloud_service_key_here
# VITE_ODCLOUD_API_BASE=/odcloud-api

# ── Vercel 프로덕션 예시 ───────────────────────────────────
# VITE_BACKEND_API_BASE=https://safemetro-busan-api.onrender.com
# VITE_KAKAO_MAP_KEY=배포_URL_등록_후_발급한_JavaScript_키

# 공공데이터 키는 Render(backend/.env)에만 — 프론트에 넣지 마세요
